{
    "compilerOptions": {
        "strict": true,
        "module": "commonjs",
        "target": "es2020",
        "lib": [
            "es2020"
        ],
        "moduleResolution": "node",
        "esModuleInterop": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "outDir": "./dist",
        "rootDir": ".",
        "resolveJsonModule": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "types": [
            "node",
            "jest"
        ]
    },
    "include": [
        "nodes/**/*.ts",
        "resources/**/*.json"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "scripts",
        "tests"
    ]
}