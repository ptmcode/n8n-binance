{
    "compilerOptions": {
        "strict": true,
        "module": "commonjs",
        "target": "es2020",
        "lib": [
            "es2020"
        ],
        "moduleResolution": "node",
        "esModuleInterop": true,
        "declaration": false,
        "sourceMap": false,
        "outDir": "./dist-scripts",
        "rootDir": ".",
        "resolveJsonModule": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "types": [
            "node"
        ]
    },
    "include": [
        "scripts/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}