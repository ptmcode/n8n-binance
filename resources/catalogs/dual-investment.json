                "description": "Default: 10, Max: 100"
            },
            {
                "name": "pageIndex",
                "type": "INT",
                "required": false,
                "description": "Default: 1"
            },
            {
                "name": "recvWindow",
                "type": "LONG",
                "required": false,
                "description": "The value cannot be greater than 60000"
            },
            {
                "name": "timestamp",
                "type": "LONG",
                "required": true,
                "description": "Current timestamp in milliseconds"
            }
        ],
        "notes": "Get Dual Investment positions (batch).",
        "docUrl": "https://developers.binance.com/docs/advanced_earn/dual-investment/trade/Get-Dual-Investment-positions"
