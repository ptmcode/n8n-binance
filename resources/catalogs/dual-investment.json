                "enumValues": [
                    "PENDING",
                    "PURCHASE_SUCCESS",
                    "SETTLED",
                    "PURCHASE_FAIL",
                    "REFUNDING",
                    "REFUND_SUCCESS",
                    "SETTLING"
                ]
            },
            {
                "name": "pageSize",
                "type": "LONG",
