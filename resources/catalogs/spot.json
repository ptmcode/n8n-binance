    {
        "id": "spot:GET:/api/v3/exchangeInfo",
        "apiGroup": "spot",
        "category": "General",
        "method": "GET",
        "path": "/api/v3/exchangeInfo",
        "security": "NONE",
        "weight": 20,
        "params": [
            {
                "name": "symbol",
                "type": "STRING",
                "required": false,
                "description": "Example: curl -X GET \"https://api.binance.com/api/v3/exchangeInfo?symbol=BNBBTC\""
            },
            {
                "name": "symbols",
                "type": "ARRAY OF STRING",
                "required": false,
                "description": "Examples: curl -X GET \"https://api.binance.com/api/v3/exchangeInfo?symbols=%5B%22BNBBTC%22,%22BTCUSDT%22%5D\" or curl -g -X GET 'https://api.binance.com/api/v3/exchangeInfo?symbols=[\"BTCUSDT\",\"BNBBTC\"]'"
            },
            {
                "name": "permissions",
                "type": "ENUM",
                "required": false,
                "description": "Examples: curl -X GET \"https://api.binance.com/api/v3/exchangeInfo?permissions=SPOT\" or curl -X GET \"https://api.binance.com/api/v3/exchangeInfo?permissions=%5B%22MARGIN%22,%22C%22,%22LEVERAGED%22%5D\" or curl -g -X GET 'https://api.binance.com/api/v3/exchangeInfo?permissions=[\"MARGIN\",\"LEVERAGED\"]'",
                "enumValues": [
                    "SPOT",
                    "MARGIN",
                    "LEVERAGED"
                ]
            },
            {
                "name": "showPermissionSets",
                "type": "BOOLEAN",
                "required": false,
                "description": "Controls whether the content of the permissionSets field is populated or not. Defaults to true"
            },
            {
                "name": "symbolStatus",
                "type": "ENUM",
                "required": false,
                "description": "Filters for symbols that have this tradingStatus. Valid values: TRADING, HALT, BREAK. Cannot be used in combination with symbols or symbol",
                "enumValues": [
                    "TRADING",
                    "HALT",
                    "BREAK"
                ]
            }
        ],
        "notes": "Current exchange trading rules and symbol information.",
        "docUrl": "https://developers.binance.com/docs/binance-spot-api-docs/rest-api#exchange-information"
    },
